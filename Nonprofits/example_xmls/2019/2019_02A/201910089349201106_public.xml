      <SupplementalInformationDetail>
        <FormAndLineReferenceDesc>Schedule G, Part III, Line 16</FormAndLineReferenceDesc>
        <ExplanationTxt>Vermont Lions Club District 45 does not have a Gaming Manager -- Various District 45 Officers/Directors manage the individual fundraising/Gaming events.</ExplanationTxt>
