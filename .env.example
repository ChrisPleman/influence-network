# Copy this file to `.env` and fill in your API keys.
# `.env` is gitignored — never commit real keys.

# Congress.gov API v3 — https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# FEC openFEC API — https://api.open.fec.gov/developers/
# Use DEMO_KEY for light testing (very low rate limit).
FEC_API_KEY=DEMO_KEY

# Senate LDA API — https://lda.senate.gov/api/register/
# Anonymous access works but is rate-limited; a key raises the limit.
LDA_API_KEY=

# Where extracted data lands
DATA_DIR=data
DB_PATH=data/irs990_full.db
